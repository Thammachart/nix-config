source = ~/.config/hypr/_init.conf

source = ~/.config/hypr/variables.conf
source = ~/.config/hypr/autostart.conf
source = ~/.config/hypr/inputs.conf
source = ~/.config/hypr/binds.conf

general {
  layout = scrolling

  gaps_in = 2
  gaps_out = 2
  border_size = 2
  col.active_border = rgba(11ee11ff) rgba(1111eeff) 45deg
  col.inactive_border = rgba(595959aa)

  resize_on_border = true
  extend_border_grab_area = 1
}

decoration {
  rounding = 2

  shadow {
    enabled = false
  }

  blur {
    enabled = false
  }
}

animations {
  enabled = true

  bezier = linear, 0, 0, 1, 1
  bezier = easeOutCirc, 0, 0.55, 0.45, 1
  bezier = overshot, 0.05, 0.9, 0.1, 1.1

  animation = global, 1, 0.1, linear

  animation = windows, 1, 2, easeOutCirc, popin 98%
  animation = windowsOut, 1, 1, linear, popin 95%

  animation = fade, 1, 1, linear

  animation = border, 1, 5, default
  animation = workspaces, 1, 3, easeOutCirc, slidevert
}

plugin {
}

scrolling {
    fullscreen_on_one_column = true
    column_width = 0.5
    follow_focus = true
    focus_fit_method = 1
}

dwindle {
  pseudotile = true
  preserve_split = true
  force_split = 1
}

master {
  orientation = center

  new_status = slave
  mfact = 0.46
}

xwayland {
  use_nearest_neighbor = true
}

misc {
  disable_autoreload = true
  disable_hyprland_logo = true
  focus_on_activate = true
}

windowrule {
    name = idleinhibit-fullscreen
    match:class = *
    # match:fullscreen = true

    idle_inhibit = fullscreen
}

windowrule {
    name = floating-dialog
    match:class = (xdg-desktop-portal-gtk)

    float = on
}
