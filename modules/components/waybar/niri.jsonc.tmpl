// -*- mode: jsonc -*-

// Courtesy to https://github.com/Sudhboi/niri-rice-dotfiles
{
  "layer": "top",
  "position": "left",
  //"height"
  "margin-top": 4,
  "margin-bottom": 4,
  "margin-left": 4,
  "width": 36,

  "modules-left": ["group/apps", "niri/workspaces"],

  "modules-center": ["niri/window"],

  "modules-right": [
    "network",
    "group/stats",
    "niri/language",
    "tray",
    "privacy",
    "clock",
    "group/power",
  ],

  "clock": {
    // "timezone": "America/New_York",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "format-alt": "{:%d\n%m\n%y}",
    "format": "{:%H\n%M}",
    "interval": 60,
  },

  "privacy": {
    "icon-spacing": 2,
  },

  "pulseaudio": {
    "format": "{volume}\n{icon}",
    "format-bluetooth": "{volume}%\n{icon}´èö\n{format_source}",
    "format-bluetooth-muted": "´æĞ\n{icon}´èö\n{format_source}",
    "format-muted": "MUT\n¾░Øş",
    "format-source": "{volume}%\n´ä░",
    "format-source-muted": "´ä▒",
    "format-icons": {
      "headphone": "´ÇÑ",
      "hands-free": "¾░ïï",
      "headset": "¾░ïÄ",
      "phone": "´éò",
      "portable": "´éò",
      "car": "´å╣",
      "default": ["´ÇĞ", "´Çğ", "´Ç¿"],
    },
    "on-click": "pactl set-sink-mute 0 toggle",
    "tooltip": false,
    "justify": "center",
    "reverse-scrolling": true,
  },

  "pulseaudio/slider": {
    "min": 0,
    "max": 100,
    "orientation": "vertical",
  },

  "group/audio": {
    "modules": ["pulseaudio", "pulseaudio/slider"],
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 500,
      "transition-left-to-right": true,
    },
  },

  "backlight": {
    "format": "{percent}\n{icon}",
    "format-icons": ["¯Äı", "¯Åô", "¯Åæ", "¯ÅÅ", "¯ÅÄ", "¯Åı", "¯Åè", "¯Åê", "¯Äø"],
    "tooltip": false,
    "justify": "center",
    "reverse-scrolling": true,
  },

  "backlight/slider": {
    "min": 3,
    "max": 100,
    "orientation": "vertical",
  },

  "group/brightness": {
    "modules": ["backlight", "backlight/slider"],
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 500,
      "transition-left-to-right": true,
    },
  },

  "battery": {
    "states": {
      // "good": 95,
      "warning": 30,
      "critical": 15,
    },
    "format": "{capacity}\n{icon}",
    "format-full": "{capacity}\n{icon}",
    "format-charging": "{capacity}\n´çĞ",
    "format-plugged": "{capacity}\n¯¼¡",
    //"format-alt": "{time} {icon}",
    "tooltip-format": "{power} W, {timeTo}",
    // "format-good": "", // An empty format will hide the module
    // "format-full": "",
    "format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"],
    "justify": "center",
  },

  "group/stats": {
    "modules": ["battery", "group/audio", "group/brightness"],
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 750,
      "transition-left-to-right": false,
    },
  },

  "niri/window": {
    "tooltip": false,
    "format": "{}",
    "rotate": 270,
    "rewrite": {
      "^null$": "Desktop",
    },
  },

  "niri/workspaces": {
    "format": "{icon}",
    "format-icons": {
      // Icons by state
      "active": "¾░╗â",
      "default": "¾░ä░",
    },
  },

  "niri/language": {
    "format": "{}",
    "format-en": "us",
    "format-th": "th",
  },

  "custom/appmenu": {
    "format": "¾░Ç╗",
    "on-click": "niri msg action toggle-overview",
    "tooltip": false,
  },

  "wlr/taskbar": {
    "format": "{icon}",
    "on-click": "activate",
    "on-click-right": "close",
  },

  "group/apps": {
    "modules": ["custom/appmenu", "wlr/taskbar"],
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 500,
      "transition-left-to-right": false,
    },
  },

  "tray": {
    "icon-size": 16,
    "spacing": 5,
  },

  "network": {
    // "interface": "wlp2*", // (Optional) To force the use of this interface
    "format-wifi": "¾░û®",
    "format-ethernet": "{ipaddr}/{cidr} ´Şû",
    //"tooltip-format": "{ifname} via {gwaddr} ",
    "tooltip-format": "{essid}: {ipaddr}",
    "format-linked": "{ifname} (No IP) ÔÜá",
    "format-disconnected": "Disconnected ÔÜá",
    "format-alt": "{ifname}: {ipaddr}/{cidr}: {essid}",
    "rotate": 270,
  },

  "group/power": {
    "modules": [
      "custom/powerbutton",
      "custom/reboot",
      "custom/suspend",
      "custom/lock",
      "custom/idlekiller",
      "user",
    ],
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 500,
    },
  },

  "custom/powerbutton": {
    "format": "ÔÅ╗",
    "on-click": "poweroff",
    "tooltip-format": "Power Off",
  },

  "custom/reboot": {
    "format": "¾░£ë",
    "on-click": "reboot",
    "tooltip-format": "Reboot",
  },

  "custom/suspend": {
    "format": "´ô«",
    "on-click": "systemctl suspend",
    "tooltip-format": "Suspend",
  },

  "custom/lock": {
    "format": "¾░ıü",
    "on-click": "hyprlock",
    "tooltip-format": "Lock",
  },

  "custom/idlekiller": {
    "format": "´ü«",
    "on-click": "pkill hypridle || hypridle",
    "tooltip-format": "Inhibit Idle",
  },

  "user": {
    "format": "{work_H}:{work_M}:{work_S} Ôåæ",
    "interval": 60,
    "rotate": 270,
  },

  "custom/playpause": {
    "format": "¾░ÉÄ",
    "on-click": "playerctl play-pause",
    "tooltip": false,
  },

  "custom/wallpaper": {
    "format": "¾░©ë",
    "on-click": "qs ipc call panelWindow toggleWallpaperSwitcher",
    "tooltip": false,
  },
}
