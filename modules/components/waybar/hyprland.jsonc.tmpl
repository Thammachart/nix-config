// -*- mode: jsonc -*-

// Courtesy to https://github.com/Sudhboi/niri-rice-dotfiles
{
  "layer": "top",
  "position": "left",
  //"height"
  "margin-top": 4,
  "margin-bottom": 4,
  "margin-left": 4,
  "width": 36,

  "modules-left": ["group/apps", "hyprland/workspaces"],

  "modules-center": ["hyprland/window"],

  "modules-right": [
    "network",
    "group/stats",
    "hyprland/language",
    "tray",
    "privacy",
    "clock",
    "group/power",
  ],

  "clock": {
    // "timezone": "America/New_York",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "format-alt": "{:%d\n%m\n%y}",
    "format": "{:%H\n%M}",
    "interval": 60,
  },

  "privacy": {
    "icon-spacing": 2,
  },

  "pulseaudio": {
    // "scroll-step": 1, // %, can be a float
    "format": "{volume}\n{icon}",
    "format-bluetooth": "{volume}%\n{icon}пЉ”\n{format_source}",
    "format-bluetooth-muted": "п‘¦\n{icon}пЉ”\n{format_source}",
    "format-muted": "MUT\nу°ќџ",
    "format-source": "{volume}%\nп„°",
    "format-source-muted": "п„±",
    "format-icons": {
      "headphone": "пЂҐ",
      "hands-free": "у°‹‹",
      "headset": "у°‹Ћ",
      "phone": "п‚•",
      "portable": "п‚•",
      "car": "п†№",
      "default": ["пЂ¦", "пЂ§", "пЂЁ"],
    },
    "on-click": "pactl set-sink-mute 0 toggle",
    "tooltip": false,
    "justify": "center",
    "reverse-scrolling": true,
  },

  "pulseaudio/slider": {
    "min": 0,
    "max": 100,
    "orientation": "vertical",
  },

  "group/audio": {
    "modules": ["pulseaudio", "pulseaudio/slider"],
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 500,
      "transition-left-to-right": true,
    },
  },

  "backlight": {
    "format": "{percent}\n{icon}",
    "format-icons": ["оЋЌ", "оЏ“", "оЏ‘", "оЏЏ", "оЏЋ", "оЏЌ", "оЏЉ", "оЏ€", "оЋ›"],
    "tooltip": false,
    "justify": "center",
    "reverse-scrolling": true,
  },

  "backlight/slider": {
    "min": 3,
    "max": 100,
    "orientation": "vertical",
  },

  "group/brightness": {
    "modules": ["backlight", "backlight/slider"],
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 500,
      "transition-left-to-right": true,
    },
  },

  "battery": {
    "states": {
      // "good": 95,
      "warning": 30,
      "critical": 15,
    },
    "format": "{capacity}\n{icon}",
    "format-full": "{capacity}\n{icon}",
    "format-charging": "{capacity}\nп‡¦",
    "format-plugged": "{capacity}\nо¬­",
    //"format-alt": "{time} {icon}",
    "tooltip-format": "{power} W, {timeTo}",
    // "format-good": "", // An empty format will hide the module
    // "format-full": "",
    "format-icons": ["п‰„", "п‰ѓ", "п‰‚", "п‰Ѓ", "п‰Ђ"],
    "justify": "center",
  },

  "group/stats": {
    "modules": ["battery", "group/audio", "group/brightness"],
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 750,
      "transition-left-to-right": false,
    },
  },

  "hyprland/window": {
    "tooltip": false,
    "format": "{}",
    "rotate": 270,
    "rewrite": {
      "^null$": "Desktop",
    },
  },

  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      // Icons by state
      "active": "у°»ѓ",
      "default": "у°„°",
    },
  },

  "hyprland/language": {
    "format": "{}",
    "format-en": "us",
    "format-th": "th",
  },

  "custom/appmenu": {
    "format": "у°Ђ»",
    "on-click": "niri msg action toggle-overview",
    "tooltip": false,
  },

  "wlr/taskbar": {
    "format": "{icon}",
    "on-click": "activate",
    "on-click-right": "close",
  },

  "group/apps": {
    "modules": ["custom/appmenu", "wlr/taskbar"],
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 500,
      "transition-left-to-right": false,
    },
  },

  "tray": {
    "icon-size": 16,
    "spacing": 5,
  },

  "network": {
    // "interface": "wlp2*", // (Optional) To force the use of this interface
    "format-wifi": "у°–©",
    "format-ethernet": "{ipaddr}/{cidr} пћ–",
    //"tooltip-format": "{ifname} via {gwaddr} ",
    "tooltip-format": "{essid}: {ipaddr}",
    "format-linked": "{ifname} (No IP) вљ ",
    "format-disconnected": "Disconnected вљ ",
    "format-alt": "{ifname}: {ipaddr}/{cidr}: {essid}",
    "rotate": 270,
  },

  "group/power": {
    "modules": [
      "custom/powerbutton",
      "custom/reboot",
      "custom/suspend",
      "custom/lock",
      "custom/idlekiller",
      "user",
    ],
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 500,
    },
  },

  "custom/powerbutton": {
    "format": "вЏ»",
    "on-click": "poweroff",
    "tooltip-format": "Power Off",
  },

  "custom/reboot": {
    "format": "у°њ‰",
    "on-click": "reboot",
    "tooltip-format": "Reboot",
  },

  "custom/suspend": {
    "format": "п“®",
    "on-click": "systemctl suspend",
    "tooltip-format": "Suspend",
  },

  "custom/lock": {
    "format": "у°ЌЃ",
    "on-click": "hyprlock",
    "tooltip-format": "Lock",
  },

  "custom/idlekiller": {
    "format": "пЃ®",
    "on-click": "pkill hypridle || hypridle",
    "tooltip-format": "Inhibit Idle",
  },

  "user": {
    "format": "{work_H}:{work_M}:{work_S} в†‘",
    "interval": 60,
    "rotate": 270,
  },

  "custom/playpause": {
    "format": "у°ђЋ",
    "on-click": "playerctl play-pause",
    "tooltip": false,
  },

  "custom/wallpaper": {
    "format": "у°ё‰",
    "on-click": "qs ipc call panelWindow toggleWallpaperSwitcher",
    "tooltip": false,
  },
}
